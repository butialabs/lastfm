# Application URL (used in OAuth redirects)
APP_URL=http://localhost:8080

# Database
DB_CONNECTION=sqlite
SQLITE_PATH=data/db/lastfm.sqlite

# Last.fm API
LASTFM_API=your_lastfm_api_key

# Last.fm API retry settings
LASTFM_MAX_RETRIES=3

# Security (32 characters recommended)
ENCRYPTION_KEY=your_32_char_encryption_key_123456

# Admin access
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_password

# Proxy fallback (used when direct requests to Last.fm are blocked)
# LASTFM_PROXY_LIST=
# LASTFM_PROXY_LIST_URL=
# LASTFM_PROXY_PROTOCOL=http
# LASTFM_PROXY_LIST_TTL=86400

# Optional jitter between requests (milliseconds)
# LASTFM_FETCH_JITTER_MIN_MS=0
# LASTFM_FETCH_JITTER_MAX_MS=0
