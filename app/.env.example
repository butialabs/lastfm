APP_NAME=LastFM
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=sqlite
# DB_DATABASE=data/db/database.db
# SQLITE_PATH=data/db/lastfm.sqlite   (legacy — import only)

SESSION_DRIVER=file
SESSION_LIFETIME=120

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Last.fm API (https://www.last.fm/api/account/create)
LASTFM_API=

# Legacy encryption — required only on the first boot to import
# credentials from the old database (lastfm.sqlite). Can be removed afterwards.
ENCRYPTION_KEY=

# Admin — initial panel seed (admins table)
ADMIN_USER=admin
ADMIN_PASSWORD=

# Optional integrations
# LASTFM_PROXY_URL=
# FANART_API_KEY=
# THEAUDIODB_API_KEY=123

# Send attempts before giving up until next week
# MAX_ERROR_COUNT=3
