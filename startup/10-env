#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_success() {
    echo -e "${GREEN}[✓] $1${NC}"
}

log_info() {
    echo -e "${YELLOW}[i] $1${NC}"
}

log_error() {
    echo -e "${RED}[✗] $1${NC}"
}

# Validate required environment variables
REQUIRED_VARS=("APP_URL" "LASTFM_API" "ENCRYPTION_KEY" "ADMIN_USER" "ADMIN_PASSWORD")
MISSING_VARS=()

for VAR in "${REQUIRED_VARS[@]}"; do
    if [ -z "${!VAR}" ]; then
        MISSING_VARS+=("$VAR")
    fi
done

if [ ${#MISSING_VARS[@]} -ne 0 ]; then
    log_error "The following required environment variables are not set:"
    for VAR in "${MISSING_VARS[@]}"; do
        echo -e "${RED}  - $VAR${NC}"
    done
    exit 1
fi

log_success "All required environment variables are set"

# Create .env file with environment variables
# Using printf to safely write values — heredoc with unquoted delimiter expands
# special characters like $$, !, \, ` before writing, corrupting the values.
log_info "Setting up environment variables in /app/.env..."
{
    printf 'APP_URL=%s\n'        "${APP_URL}"
    printf 'DB_CONNECTION=sqlite\n'
    printf 'SQLITE_PATH=data/db/lastfm.sqlite\n'
    printf 'LASTFM_API=%s\n'     "${LASTFM_API}"
    printf 'ENCRYPTION_KEY=%s\n' "${ENCRYPTION_KEY}"
    printf 'ADMIN_USER=%s\n'     "${ADMIN_USER}"
    printf 'ADMIN_PASSWORD=%s\n' "${ADMIN_PASSWORD}"
} > /app/.env

log_success "Environment variables set in /app/.env"