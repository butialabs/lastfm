#!/bin/bash
set -e

# Required env vars (ENCRYPTION_KEY is optional — only for the legacy import)
for VAR in APP_URL LASTFM_API ADMIN_USER ADMIN_PASSWORD; do
    if [ -z "${!VAR}" ]; then
        echo "[?] Missing required environment variable: $VAR" >&2
        exit 1
    fi
done

# Resolve APP_KEY: env → data/.app_key (volume) → generate and persist
if [ -z "${APP_KEY}" ] && [ -f /app/data/.app_key ]; then
    APP_KEY=$(cat /app/data/.app_key)
fi
if [ -z "${APP_KEY}" ]; then
    APP_KEY=$(php /app/artisan key:generate --show)
    printf '%s' "${APP_KEY}" > /app/data/.app_key
    chown www-data:www-data /app/data/.app_key
    echo "[V] APP_KEY generated and persisted in /app/data/.app_key"
fi

# printf avoids expansion of special characters ($$, !, \, `) in values
{
    printf 'APP_NAME=LastFM\n'
    printf 'APP_ENV=production\n'
    printf 'APP_DEBUG=false\n'
    printf 'APP_KEY=%s\n'        "${APP_KEY}"
    printf 'APP_URL=%s\n'        "${APP_URL}"
    printf 'DB_CONNECTION=sqlite\n'
    printf 'SESSION_DRIVER=file\n'
    printf 'CACHE_STORE=file\n'
    printf 'QUEUE_CONNECTION=sync\n'
    printf 'LASTFM_API=%s\n'     "${LASTFM_API}"
    printf 'ENCRYPTION_KEY=%s\n' "${ENCRYPTION_KEY:-}"
    printf 'ADMIN_USER=%s\n'     "${ADMIN_USER}"
    printf 'ADMIN_PASSWORD=%s\n' "${ADMIN_PASSWORD}"
    printf 'THEAUDIODB_API_KEY=%s\n'  "${THEAUDIODB_API_KEY:-}"
    printf 'FANART_API_KEY=%s\n'      "${FANART_API_KEY:-}"
    [ -n "${LASTFM_PROXY_URL}" ] && printf 'LASTFM_PROXY_URL=%s\n' "${LASTFM_PROXY_URL}"
    [ -n "${MAX_ERROR_COUNT}" ]  && printf 'MAX_ERROR_COUNT=%s\n'  "${MAX_ERROR_COUNT}"
} > /app/.env

echo "[V] Environment ready (/app/.env)"
